{
  "permissions": {
    "allow": [
      "Bash(./build/scripts/*.sh)",
      "Bash(/tmp/*)",
      "Bash(/tmp/check-critical-issues.sh:*)",
      "Bash(asciidoctor titles/*)",
      "Bash(build/scripts/build-*.sh *)",
      "Bash(build/scripts/build-ccutil.sh)",
      "Bash(build/scripts/build.sh)",
      "Bash(ccutil compile *)",
      "Bash(chmod +x /tmp/check-critical-issues.sh)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(for file in */*/*.adoc)",
      "Bash(gh api *)",
      "Bash(gh pr:*)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit:*)",
      "Bash(git mv *)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git reset HEAD *)",
      "Bash(git restore*)",
      "Bash(git rm *)",
      "Bash(git stash:*)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(podman run *)",
      "Bash(rm *)",
      "Bash(sed *)",
      "Bash(tee *)",
      "Bash(vale *)",
      "Bash(xargs *)",
      "Read(//assemblies/**)",
      "Read(//modules/**)",
      "Read(//titles/**)",
      "Read(//tmp/**)",
      "WebFetch(domain:*)"
    ],
    "additionalDirectories": [
      ".claude",
      "/tmp"
    ]
  }
}
