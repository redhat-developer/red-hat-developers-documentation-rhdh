{
  "permissions": {
    "allow": [
      "Bash(./build/scripts/*.sh*)",
      "Bash(/tmp/*.sh)",
      "Bash(file *)",
      "Bash(gh api *)",
      "Bash(gh pr:*)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit:*)",
      "Bash(git mv *)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git restore*)",
      "Bash(git rm *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(podman run *)",
      "Bash(rm -f *)",
      "Bash(vale *)",
      "Bash(xargs *)",
      "Read(//tmp/**)",
      "WebFetch(domain:*)"
    ],
    "additionalDirectories": [
      "/tmp",
      ".claude"
    ]
  }
}
