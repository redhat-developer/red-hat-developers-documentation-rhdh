# Relative index pages (navigation links in generated HTML)

# lychee resolves these to file:// URIs, so match on the path

file://.*titles-generated/(main|pr-.*|release-.*|rhdh-.*|1\.\d+\.x)/index\.html$
file://.*titles-generated/pulls\.html$
file://.*titles-generated/index\.html$

# Cross-title links checked online; exclude titles with slug changes (see RHDHBUGS-XXXX for remapping)

^https://docs\.redhat\.com/en/documentation/red_hat_developer_hub/1\.9/html-single/integrating_red_hat_developer_hub_with_your_git_provider/index

# External sites that block automated requests
^https://fonts\.google\.com/icons
